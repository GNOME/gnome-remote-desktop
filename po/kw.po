#: data/org.gnome.remotedesktop.configure-system-daemon.policy.in:11
msgid "Allow to configure gnome-remote-desktop's system daemon settings"
msgstr "Gasa selya an settyansow oberer system gnome-remote-desktop "

#: data/org.gnome.remotedesktop.configure-system-daemon.policy.in:12
msgid ""
"Authentication is required to configure gnome-remote-desktop's system daemon "
"settings"
msgstr ""
"Omgelmyans a res rag selya an settyansow oberer system gnome-remote-desktop"

#: data/org.gnome.remotedesktop.enable-system-daemon.policy.in:11
msgid "Allow to enable and disable gnome-remote-desktop's system daemon"
msgstr "Gasa rag bywhe ha marowhe an oberer system gnome-remote-desktop"

#: data/org.gnome.remotedesktop.enable-system-daemon.policy.in:12
msgid ""
"Authentication is required to enable or disable gnome-remote-desktop's "
"system daemon"
msgstr ""
"Omgelmyans a res rag bywhe po marowhe an oberer system gnome-remote-desktop"

#: src/grd-ctl.c:72
#, c-format
msgid "Usage: %s [OPTIONS...] COMMAND [SUBCOMMAND]...\n"
msgstr "Usadow: %s [DEWISYOW...] ARGHADOW [ISARGHADOW]...\n"

#: src/grd-ctl.c:382
msgid "Username: "
msgstr "Hanow devnydhyer:"

#: src/grd-ctl.c:394 src/grd-ctl.c:552
msgid "Password: "
msgstr "Ger-tremena:"

#: src/grd-ctl.c:682
msgid "Commands:\n"
msgstr "Arghadowyow:\n"

#: src/grd-ctl.c:687
msgid ""
"  rdp                                            - RDP subcommands:\n"
"    set-port                                     - Set port the server binds "
"to\n"
"    enable                                       - Enable the RDP backend\n"
"    disable                                      - Disable the RDP backend\n"
"    set-auth-methods <list-of-methods>           - Set a comma separated "
"list of\n"
"                                                   allowed authentication "
"methods\n"
"                                                   (credentials, kerberos)\n"
"    set-tls-cert <path-to-cert>                  - Set path to TLS "
"certificate\n"
"    set-tls-key <path-to-key>                    - Set path to TLS key\n"
"    set-kerberos-keytab <path-to-keytab>         - Set path to a Kerberos "
"keytab\n"
"    set-credentials [<username> [<password>]]    - Set username and "
"password\n"
"                                                   credentials\n"
"    clear-credentials                            - Clear username and "
"password\n"
"                                                   credentials\n"
"    enable-view-only                             - Disable remote control of "
"input\n"
"                                                   devices\n"
"    disable-view-only                            - Enable remote control of "
"input\n"
"                                                   devices\n"
"    enable-port-negotiation                      - If unavailable, listen "
"to\n"
"                                                   a different port\n"
"    disable-port-negotiation                     - If unavailable, don't "
"listen\n"
"                                                   to a different port\n"
"\n"
msgstr ""
"  rdp                                            - isarghadow RDP:\n"
"    set-port                                     - Gorra porth an servell a "
"jun dhe\n"
"    enable                                       - Bywhe RDP\n"
"    disable                                      - Marowhe RDP\n"
"    set-auth-methods <list-of-methods>           - Gorra rol dhiberthys gans "
"kommas a\n"
"                                                   vethodys omgelmans gesys\n"
"                                                   (manylyon, kerberos)\n"
"    set-tls-cert <path-to-cert>                  - Gorra tyller testskrif "
"TLS\n"
"    set-tls-key <path-to-key>                    - Gorra tyller alhwedh TLS\n"
"    set-credentials [<username> [<password>]]    - Gorra hanow devnydhyer ha "
"ger-tremena\n"
"    clear-credentials                            - Dilea hanow devnydhyer ha "
"ger-tremena\n"
"    enable-view-only                             - Marowhe routyans pell "
"devisyow\n"
"                                                   ynworrans\n"
"    disable-view-only                            - Marowhe routyans pell "
"devisyow\n"
"                                                   ynworrans\n"
"    enable-port-negotiation                      - Mars ankavadow, goslowes "
"orth\n"
"                                                   porth aral\n"
"    disable-port-negotiation                     - Mars ankavadow, na "
"woslowes\n"
"                                                   orth porth aral\n"
"\n"

#: src/grd-ctl.c:715
msgid ""
"  vnc                                        - VNC subcommands:\n"
"    set-port                                 - Set port the server binds to\n"
"    enable                                   - Enable the VNC backend\n"
"    disable                                  - Disable the VNC backend\n"
"    set-password [<password>]                - Set the VNC password\n"
"    clear-password                           - Clear the VNC password\n"
"    set-auth-method password|prompt          - Set the authorization method\n"
"    enable-view-only                         - Disable remote control of "
"input\n"
"                                               devices\n"
"    disable-view-only                        - Enable remote control of "
"input\n"
"                                               devices\n"
"    enable-port-negotiation                  - If unavailable, listen to\n"
"                                               a different port\n"
"    disable-port-negotiation                 - If unavailable, don't listen\n"
"                                               to a different port\n"
"\n"
msgstr ""
"  vnc                                        - isarghadow VNC:\n"
"    set-port                                 - Gorra porth an servell a jun "
"dhe\n"
"    enable                                   - Bywhe VNC\n"
"    disable                                  - Marowhe VNC\n"
"    set-password [<password>]                - Gorra an ger-tremena VNC\n"
"    clear-password                           - Dilea an ger-tremena VNC\n"
"    set-auth-method password|prompt          - Gorra an method reythheans\n"
"    enable-view-only                         - Marowhe routyans pell "
"devisyow\n"
"                                               ynworrans\n"
"    disable-view-only                        - Bywhe routyans pell devisyow\n"
"                                               ynworrans\n"
"    enable-port-negotiation                  - Mars ankavadow, goslowes "
"orth\n"
"                                               porth aral\n"
"    disable-port-negotiation                 - Mars ankavadow, na woslowes\n"
"                                               orth porth aral\n"
"\n"

#: src/grd-ctl.c:735
msgid ""
"  status [--show-credentials]                - Show current status\n"
"\n"
"Options:\n"
"  --headless                                 - Configure headless daemon\n"
"                                               running on a user session\n"
"  --system                                   - Configure system daemon\n"
"                                               for remote login\n"
"  --help                                     - Print this help text\n"
msgstr ""
"  status [--show-credentials]                - Diskwedhes studh a-lemmyn\n"
"\n"
"Dewisyow:\n"
"  --headless                                 - Selya oberer heb penn\n"
"                                               owth eksekutya war esedhek "
"devnydhyer\n"
"  --system                                   - Selya oberer system\n"
"                                               rag omgelmyans pell\n"
"  --help                                     - Pryntya an tekst gweres ma\n"

#: src/grd-daemon.c:1165
msgid "GNOME Remote Desktop"
msgstr "Pelldesktop GNOME"

#: src/grd-daemon-handover.c:331 src/grd-daemon-handover.c:396
#, c-format
msgid "Continue With Insecure Connection?"
msgstr "Pesya gans Junyans Ansaw?"

#. Translators: Don't translate “use redirection server name:i:1”.
#. * It's a menu option, and it's the same for all languages.
#: src/grd-daemon-handover.c:334 src/grd-daemon-handover.c:400
#, c-format
msgid ""
"This Remote Desktop connection is insecure. To secure this connection, "
"enable RDSTLS Security in your client by saving the connection settings in "
"your client as an RDP file and set “use redirection server name:i:1” in it."
msgstr ""
"An junyans Pelldesktop ma yw ansaw. Rag diogeli an junyans ma, bywhe "
"Diogeledh RDSTLS y'gas kliens gans ow sawya an settyansow junyans y'gas "
"kliens avel restren RDP ha gorra “devnydhya servell dhaskevarwodhyans "
"hanow:i:1” ynno."

#: src/grd-daemon-handover.c:339 src/grd-daemon-handover.c:405
#, c-format
msgid "Disconnect"
msgstr "Disjunya"

#: src/grd-daemon-handover.c:340 src/grd-daemon-handover.c:406
#, c-format
msgid "Continue"
msgstr "Pesya"

#: src/grd-daemon-user.c:99
#, c-format
msgid "Desktop Sharing port changed"
msgstr "Porth Ow Kevrenna Desktop chanjys"

#: src/grd-daemon-user.c:101
#, c-format
msgid ""
"The Desktop Sharing port has changed from <b>%i</b> to <b>%i</b>.\n"
"This is because the Remote Sessions service has been activated and it has a "
"higher priority to use port <b>%i</b>."
msgstr ""
"An porth Ow Kevrenna Desktop re janjys dhyworth <b>%i</b> dhe <b>%i</b>.\n"
"Hemm yw drefen an gonis Esedhogow Pell yw bywhes hag yma ragwir ughella dhe "
"dhevnydhya porth <b>%i</b>."

#: src/grd-daemon-user.c:107 src/grd-session-vnc.c:323
#, c-format
msgid "Accept"
msgstr "Receva"

#: src/grd-session-vnc.c:318
#, c-format
msgid "Do you want to share your desktop?"
msgstr "A vynnowgh kevrenna agas desktop?"

#: src/grd-session-vnc.c:320
#, c-format
msgid ""
"A user on the computer '%s' is trying to remotely view or control your "
"desktop."
msgstr ""
"Yma devnydhyer war'n amontyell '%s' owth assaya dhe weles po routya yn pell "
"agas desktop."

#: src/grd-session-vnc.c:322
#, c-format
msgid "Refuse"
msgstr "Nagha"

#: src/org.gnome.desktop.remote-desktop.gschema.xml.in:7
#: src/org.gnome.desktop.remote-desktop.gschema.xml.in:101
msgid "The port used by the RDP server"
msgstr "An porth devnydhys gans an servell RDP"

#: src/org.gnome.desktop.remote-desktop.gschema.xml.in:8
#: src/org.gnome.desktop.remote-desktop.gschema.xml.in:102
msgid "The RDP client will connect to this port to use this RDP server."
msgstr ""
"An kliens RDP a wra junya orth an porth ma rag devnydhya an servell RDP ma."

#: src/org.gnome.desktop.remote-desktop.gschema.xml.in:14
#: src/org.gnome.desktop.remote-desktop.gschema.xml.in:108
msgid "Search a different RDP port if the configured one is used"
msgstr "Hwilas porth RDP aral mar devnydhys yw an porth selys"

#: src/org.gnome.desktop.remote-desktop.gschema.xml.in:15
#: src/org.gnome.desktop.remote-desktop.gschema.xml.in:109
msgid ""
"When negotiate-port is set to 'true' the RDP server will attempt to listen "
"to the first available of the next 10 ports starting from the configured one."
msgstr ""
"Pan negotiate-port yw gorrys dhe 'true' an servell RDP a wra assaya dhe "
"woslowes orth an kynsa kavadow a'n borthow 10 nessa, ow talleth dhyworth an "
"unn selys."

#: src/org.gnome.desktop.remote-desktop.gschema.xml.in:23
#: src/org.gnome.desktop.remote-desktop.gschema.xml.in:117
msgid "Whether the RDP backend is enabled or not"
msgstr "Po RDP yw byw po na"

#: src/org.gnome.desktop.remote-desktop.gschema.xml.in:24
#: src/org.gnome.desktop.remote-desktop.gschema.xml.in:118
msgid "If set to 'true' the RDP backend will be initialized."
msgstr "Mar gorra dhe 'true' RDP a vydh bywhys."

#: src/org.gnome.desktop.remote-desktop.gschema.xml.in:30
msgid "Screenshare mode of RDP connections"
msgstr "Fordh skrin-kevrenna a junyansow RDP"

#: src/org.gnome.desktop.remote-desktop.gschema.xml.in:31
msgid ""
"The screenshare mode specifies, whether the RDP backend mirrors the primary "
"screen, or whether a virtual monitor is created. For the initial resolution "
"of the virtual monitor, the RDP backend uses either the client core data "
"([MS-RDPBCGR] 2.2.1.3.2) or the client monitor data ([MS-RDPBCGR] "
"2.2.1.3.6), depending on what is available. When using a remote desktop "
"session with a virtual monitor, clients can resize the resolution of the "
"virtual monitor during a session with the Display Update Virtual Channel "
"Extension ([MS-RDPEDISP]). Allowed screenshare modes include: * mirror-"
"primary - Record the primary monitor of the current user session. * extend - "
"Create a new virtual monitor and use it for the remote desktop session. The "
"resolution of this virtual monitor is derived from the monitor "
"configuration, submitted by the remote desktop client."
msgstr ""
"An fordh skrin-kevrenna a ragnot, po RDP a dhiskwedh an skrin chif, po skrin "
"gowir yw gwrys. Rag an braster kynsa a'n skrin wowir, RDP a dhevnydh po an "
"data kolonnen kliens ([MS-RDPBCGR] 2.2.1.3.2) po an data skrin gliens ([MS-"
"RDPBCGR] 2.2.1.3.6), ow kregi war pyth yw kavadow. Pan ow tevnydhya esedhek "
"pelldesktop gans skrin wowir, kliensow a yll chanjya an braster a'n skrin "
"wowir dres esedhek gans an Display Update Virtual Channel Extension ([MS-"
"RDPEDISP]). Fordhow skrin-kevrenna gesys a syns: * mirror-primary - Rekordya "
"an skrin chif a'n esedhek devnydhyer a-lemmyn. * extend - Gwruthyl skrin "
"wowir nowydh hag a'n devnydhya rag an esedhek pelldesktop. An braster a'n "
"skrin wowir yw dhyworth an selyans skrin, danvenys gans an kliens "
"pelldesktop."

#: src/org.gnome.desktop.remote-desktop.gschema.xml.in:57
msgid "Path to the certificate file"
msgstr "Tyller dhe'n restren destskrif"

#: src/org.gnome.desktop.remote-desktop.gschema.xml.in:58
#: src/org.gnome.desktop.remote-desktop.gschema.xml.in:66
msgid ""
"In order to be able to use RDP with TLS Security, both the private key file "
"and the certificate file need to be provided to the RDP server."
msgstr ""
"Rag devnydhya RDP gans Diogeledh TLS, res yw dhe'n dhiw an restren alhwedh "
"privedh hag an restren destskrif bos provys dhe'n servell RDP."

#: src/org.gnome.desktop.remote-desktop.gschema.xml.in:65
msgid "Path to the private key file"
msgstr "Tyller dhe'n restren alhwedh privedh"

#: src/org.gnome.desktop.remote-desktop.gschema.xml.in:73
#: src/org.gnome.desktop.remote-desktop.gschema.xml.in:167
msgid "Only allow remote connections to view the screen content"
msgstr "Gasa junyans pell hepken dhe weles an synsas skrin"

#: src/org.gnome.desktop.remote-desktop.gschema.xml.in:74
msgid ""
"When view-only is true, remote RDP connections cannot manipulate input "
"devices (e.g. mouse and keyboard)."
msgstr ""
"Pan view-only yw gwir, junyansow RDP pell ny allas handla devisyow ynworrans "
"(r.e logosen ha bysowek)."

#: src/org.gnome.desktop.remote-desktop.gschema.xml.in:81
#: src/org.gnome.desktop.remote-desktop.gschema.xml.in:124
msgid "Allowed authentication methods"
msgstr "Methods omgelmans gesys"

#: src/org.gnome.desktop.remote-desktop.gschema.xml.in:82
#: src/org.gnome.desktop.remote-desktop.gschema.xml.in:125
msgid ""
"Allowed authentication methods. Multiple may be selected to allow different "
"authentication mechanisms. At least one authentication method must be "
"selected."
msgstr ""
"Methods omgelmans gesys. Liesek a yll bos dewisys rag gasa jynnweythow "
"omgelmans dyffrans. Dhe'n lyha, res yw dhe unn method bos dewisys."

#: src/org.gnome.desktop.remote-desktop.gschema.xml.in:90
#: src/org.gnome.desktop.remote-desktop.gschema.xml.in:133
msgid "A path to a Kerberos keytab file"
msgstr "Tyller dhe restren alhwedhtabb Kerberos"

#: src/org.gnome.desktop.remote-desktop.gschema.xml.in:91
#: src/org.gnome.desktop.remote-desktop.gschema.xml.in:134
msgid ""
"When 'kerberos' is enabled as an authentication method, the TERMSRV Kerberos "
"service principal in this keytab file will be used for authentication."
msgstr ""
"Pan 'kerberos' yw byw avel method omgelmans, an gonis chif Kerberos TERMSRV "
"y'n restren alhwedhentabb ma a vydh devnydhys rag omgelmans."

#: src/org.gnome.desktop.remote-desktop.gschema.xml.in:144
#: src/org.gnome.desktop.remote-desktop.gschema.xml.in:216
msgid "The port used by the VNC server"
msgstr "An porth devnydhys gans an servell VNC"

#: src/org.gnome.desktop.remote-desktop.gschema.xml.in:145
#: src/org.gnome.desktop.remote-desktop.gschema.xml.in:217
msgid "The VNC client will connect to this port to use this VNC server."
msgstr ""
"An kliens VNC a wra junya orth an porth ma rag devnydhya an servell VNC ma."

#: src/org.gnome.desktop.remote-desktop.gschema.xml.in:151
#: src/org.gnome.desktop.remote-desktop.gschema.xml.in:223
msgid "Search a different VNC port if the configured one is used"
msgstr "Hwilas porth VNC aral mar devnydhys yw unn selys"

#: src/org.gnome.desktop.remote-desktop.gschema.xml.in:152
#: src/org.gnome.desktop.remote-desktop.gschema.xml.in:224
msgid ""
"When negotiate-port is set to 'true' the VNC server will attempt to listen "
"to the first available of the next 10 ports starting from the configured one."
msgstr ""
"Pan negotiate-port yw gorrys dhe 'true' an servell VNC a wra assaya dhe "
"woslowes orth an kynsa kavadow a'n porthow 10 nessa, ow talleth dhyworth an "
"unn selys."

#: src/org.gnome.desktop.remote-desktop.gschema.xml.in:160
#: src/org.gnome.desktop.remote-desktop.gschema.xml.in:232
msgid "Whether the VNC backend is enabled or not"
msgstr "Po VNC yw bywhys po na"

#: src/org.gnome.desktop.remote-desktop.gschema.xml.in:161
#: src/org.gnome.desktop.remote-desktop.gschema.xml.in:233
msgid "If set to 'true' the VNC backend will be initialized."
msgstr "Mars yw gorrys dhe 'true' VNC a vydh dallethys."

#: src/org.gnome.desktop.remote-desktop.gschema.xml.in:168
msgid ""
"When view-only is true, remote VNC connections cannot manipulate input "
"devices (e.g. mouse and keyboard)."
msgstr ""
"Pan view-only yw gwir, junyansow VNC pell ny allas handla devisyow ynworrans "
"(r.e. logosen ha bysowek)."

#: src/org.gnome.desktop.remote-desktop.gschema.xml.in:175
msgid "Method used to authenticate VNC connections"
msgstr "Method devnydhys rag gwirhe junyansow VNC"

#: src/org.gnome.desktop.remote-desktop.gschema.xml.in:176
msgid ""
"The VNC authentication method describes how a remote connection is "
"authenticated. It can currently be done in two different ways: * prompt - by "
"prompting the user for each new connection, requiring a person with physical "
"access to the workstation to explicitly approve the new connection. * "
"password - by requiring the remote client to provide a known password"
msgstr ""
"An method gwirheans VNC ow teskrifa fatel junyans pell yw gwirhys. Yth a yll "
"bos gwrys a-lemmyn yn diw agwedhow dihaval: * prompt - gans ow lostleverel "
"an devnydhyer rag pub junyans nowydh, ow rekwirya unn den gans hedhas "
"fisegel dhe'n amontyell dhe gomendya diblans an junyans nowydh. * password - "
"gans ow rekwirya an kliens pell dhe brovia ger-tremena aswonys"

#: src/org.gnome.desktop.remote-desktop.gschema.xml.in:188
msgid "Screenshare mode of VNC connections"
msgstr "Fordh skrin-kevrenna a junyansow VNC"

#: src/org.gnome.desktop.remote-desktop.gschema.xml.in:189
msgid ""
"The screenshare mode specifies, whether the VNC backend mirrors the primary "
"screen, or whether a virtual monitor is created. For the initial resolution "
"of the virtual monitor, the VNC backend uses a default size of 1920x1080 "
"pixels. When using a remote desktop session with a virtual monitor, clients "
"can resize the resolution of the virtual monitor during a session with the "
"setDesktopSize PDU. Allowed screenshare modes include: * mirror-primary - "
"Record the primary monitor of the current user session. * extend - Create a "
"new virtual monitor and use it for the remote desktop session. The initial "
"monitor resolution of this virtual monitor is set to 1920x1080 pixels. "
"Clients can override the initial resolution with subsequent monitor "
"configuration updates."
msgstr ""
"An fordh skrin-kevrenna a ragnot, po VNC a dhiskwedh an skrin jif, po skrin "
"wowir yw gwrys. Rag an braster kynsa a'n skrin wowir, VNC a dhevnydh an "
"braster defowt a 1920x1080 pyskelys. Pan ow tevnydhya esedhek pelldesktop "
"gans skrin wowir, kliens a yll chanjya an braster a'n skrin wowir dres "
"esedhek gans PDU setDesktopSize. Fordhow skrin-kevrenna gesys a syns: "
"*mirror-primary - Rekordya an skrin jif a'n esedhek devnydhyer a-lemmyn. * "
"extend - Gwruthyl skrin wowir nowydh hag a'n devnydhya rag an esedhek "
"pelldesktop. An braster kynsa a'n skrin wowir ma yw gorrys dhe 1920x1080 "
"pykselys. Kliensow a yll aslea an braster kynsa gans nowedhyansow selyans "
"skrin iskevresek."

#~ msgid "GNOME Remote Desktop Handover Daemon"
#~ msgstr "Daemon Leuvherdh Pelldesktop GNOME"
